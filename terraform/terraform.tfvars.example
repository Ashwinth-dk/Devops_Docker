# Example Terraform variables file
# Copy this to terraform.tfvars and customize

aws_region    = "us-east-1"
environment   = "dev"
instance_type = "t3.medium"
ami_id        = "ami-0c7217cdde317cfec"  # Amazon Linux 2 in us-east-1
key_name      = "organizeme-key"        # Create this key pair in AWS Console