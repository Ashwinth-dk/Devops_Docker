# Auto detect text files and normalize line endings to LF
* text=auto

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary

# Documents
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.rar binary

# Custom diff/merge for images
*.png diff=image binary
*.jpg diff=image binary
*.jpeg diff=image binary
*.gif diff=image binary
